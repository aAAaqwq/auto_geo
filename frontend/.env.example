# AutoGeo Frontend Environment Variables
# 提醒：根据部署环境修改这些值！

# ==================== 开发环境 ====================
# 后端 API 地址（开发时默认本地后端）
VITE_API_BASE_URL=http://127.0.0.1:8001/api

# WebSocket 地址
VITE_WS_BASE_URL=ws://127.0.0.1:8001/ws

# ==================== 生产环境（服务器部署后修改） ====================
# 服务器 IP：8.138.59.152
VITE_API_BASE_URL=http://8.138.59.152:8001/api
VITE_WS_BASE_URL=ws://8.138.59.152:8001/ws

# ==================== 域名访问（如果有域名） ====================
# VITE_API_BASE_URL=https://api.yourdomain.com/api
# VITE_WS_BASE_URL=wss://api.yourdomain.com/ws
