# n8n 独立部署环境变量配置
# 说明: 使用IP+端口方式访问，无需域名和SSL

# ==================== 基础配置 ====================
# 服务器IP地址（修改为你的服务器IP）
N8N_HOST=your-server-ip
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://your-server-ip:5678
WEBHOOK_URL=http://your-server-ip:5678/

# ==================== 安全认证（必填）====================
N8N_USER=admin
N8N_PASSWORD=your-secure-password-here

# ==================== 数据库配置（必填）====================
POSTGRES_PASSWORD=your-postgres-password-here

# ==================== Redis配置（必填）====================
REDIS_PASSWORD=your-redis-password-here

# ==================== 执行模式配置 ====================
# 执行模式: regular(单机) | queue(队列模式，支持多worker)
EXECUTIONS_MODE=regular

# 执行数据保留天数（默认7天）
EXECUTIONS_DATA_MAX_AGE=168

# 并发限制
N8N_CONCURRENCY=10

# ==================== 可选配置 ====================
# 时区
GENERIC_TIMEZONE=Asia/Shanghai
TZ=Asia/Shanghai
