# ==================== AutoGeo 简化部署环境变量配置 ====================
# 适用场景：仅部署后端服务 + PostgreSQL，不含 RAGFlow
#
# 部署步骤：
# 1. 复制此文件为 .env.backend: cp .env.backend.example .env.backend
# 2. 修改以下配置项
# 3. 运行部署脚本: ./deploy-simple.sh
#
# 警告：.env.backend 已在 .gitignore 中，不会被提交到 git

# ==================== 数据库配置 (PostgreSQL) ====================
# 数据库用户名
DB_USER=autogeo

# 数据库密码（必须修改！）
DB_PASSWORD=your-secure-password-here

# 数据库名
DB_NAME=autogeo

# 数据库连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ==================== 加密配置 ====================
# AES-256 加密密钥（32字节）- 生产环境必须修改！
# 用于加密存储在数据库中的 Cookies 和 localStorage
#
# 生成方法：
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
AUTO_GEO_ENCRYPTION_KEY=change-this-to-your-32-byte-key

# ==================== 后端服务配置 ====================
# 后端服务端口（默认8001，如需修改请同步修改 docker-compose）
# PORT=8001

# CORS 配置（添加你的前端地址）
# 多个地址用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ==================== n8n 工作流配置 ====================
# 如果你有单独的 n8n 服务器，请配置此处
# 否则留空，使用默认本地配置
# N8N_WEBHOOK_URL=http://your-n8n-server:5678/webhook
# N8N_API_KEY=your-n8n-api-key

# ==================== DeepSeek AI 配置 ====================
# DeepSeek API Key（用于文章生成）
DEEPSEEK_API_KEY=your-deepseek-api-key

# DeepSeek API 地址
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ==================== RAGFlow 配置（可选）====================
# 如果不部署 RAGFlow，保持注释或留空
# 如需单独部署 RAGFlow，请参考 RAGFLOW-DEPLOY.md
#
# RAGFLOW_API_KEY=your-ragflow-api-key
# RAGFLOW_BASE_URL=http://your-ragflow-server:9380

# ==================== 日志配置 ====================
LOG_LEVEL=INFO

# ==================== 镜像配置（可选）====================
# 后端镜像地址
BACKEND_IMAGE=crpi-lwz264sedmauvivo.cn-guangzhou.personal.cr.aliyuncs.com/opencaio/auto_geo_backend:latest
