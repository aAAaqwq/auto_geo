# -*- coding: utf-8 -*-
"""
部署模式配置示例
复制此文件为 .env 并修改相应配置
"""

# ==================== 部署模式配置 ====================
# 部署模式选择：
# - local: 本地模式（默认），所有浏览器操作在本地执行
# - cloud: 云端模式，所有浏览器操作headless执行
# - hybrid: 混合模式，授权在本地，自动化任务在云端
DEPLOYMENT_MODE=local

# 是否强制使用headless模式（会覆盖部署模式的设置）
HEADLESS_MODE=false

# 本地浏览器CDP端口（混合模式使用）
LOCAL_BROWSER_CDP_PORT=9222

# ==================== 服务配置 ====================
HOST=0.0.0.0
PORT=8001

# ==================== 数据库配置 ====================
# 默认使用SQLite，无需额外配置

# ==================== CORS配置 ====================
# 允许的前端地址（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:5179

# ==================== 加密配置 ====================
# 生产环境请设置随机32字节密钥
AUTO_GEO_ENCRYPTION_KEY=auto-geo-default-key-32-bytes-length!!

# ==================== 部署模式说明 ====================
#
# 【local - 本地模式】
# - 适用场景：开发环境、调试阶段
# - 浏览器：有GUI显示
# - 授权：本地手动登录
# - 发布：本地浏览器执行
# - 收录检测：本地浏览器执行
#
# 【cloud - 云端模式】
# - 适用场景：生产环境、已保存会话
# - 浏览器：headless模式
# - 授权：需要预先获取会话
# - 发布：服务器自动执行
# - 收录检测：服务器自动执行
# - 注意：需要安装xvfb（Linux无GUI环境）
#   apt-get install xvfb
#   启动命令：xvfb-run python backend/main.py
#
# 【hybrid - 混合模式】（推荐）
# - 适用场景：生产环境 + 需要手动授权
# - 浏览器：授权时本地，任务时云端
# - 授权：通过本地客户端手动登录
# - 发布：服务器自动执行（使用已保存的会话）
# - 收录检测：服务器自动执行
# - 优势：灵活性和效率兼顾
